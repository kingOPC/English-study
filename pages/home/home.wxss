.home-page {
  padding-bottom: 44rpx;
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 34rpx 32rpx 30rpx;
  border-radius: 16rpx;
  background: #173f3a;
  color: #ffffff;
  box-shadow: 0 20rpx 44rpx rgba(23, 63, 58, 0.2);
}

.hero-card::after {
  content: "";
  position: absolute;
  right: -64rpx;
  bottom: -110rpx;
  width: 280rpx;
  height: 280rpx;
  border: 46rpx solid rgba(244, 185, 73, 0.16);
  border-radius: 50%;
}

.hero-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.eyebrow {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.version-mark {
  color: #f5c96f;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 16rpx;
  max-width: 560rpx;
  position: relative;
  z-index: 1;
  font-size: 48rpx;
  font-weight: 850;
  line-height: 1.12;
}

.hero-copy {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 27rpx;
  line-height: 1.55;
}

.hero-stats {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 34rpx;
}

.hero-stats view {
  min-height: 116rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-number,
.hero-label {
  display: block;
}

.hero-number {
  font-size: 38rpx;
  font-weight: 850;
}

.hero-label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title,
.panel-title {
  font-size: 32rpx;
  font-weight: 800;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #69717c;
  font-size: 25rpx;
}

.level-card {
  min-height: 164rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 18rpx;
  padding: 26rpx;
  border: 1rpx solid #e4e8eb;
  border-left: 7rpx solid #2f8f6f;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(31, 42, 49, 0.05);
}

.level-card.high {
  border-left-color: #3f6fa9;
}

.level-card.cet {
  border-left-color: #7755a6;
}

.level-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 850;
}

.level-card.elementary .level-icon {
  background: #2f8f6f;
}

.level-card.high .level-icon {
  background: #315f9f;
}

.level-card.cet .level-icon {
  background: #6d4aa2;
}

.level-body {
  flex: 1;
  min-width: 0;
}

.level-name {
  font-size: 33rpx;
  font-weight: 820;
}

.level-desc {
  margin-top: 8rpx;
  color: #69717c;
  font-size: 24rpx;
  line-height: 1.45;
}

.level-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.level-meta text {
  min-height: 34rpx;
  color: #4d555f;
  font-size: 22rpx;
  line-height: 34rpx;
}

.level-meta text + text::before {
  content: "·";
  margin-right: 10rpx;
  color: #b4bbc1;
}

.level-meta .word-count {
  color: #20242a;
  font-weight: 750;
}

.level-progress-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.level-progress-track {
  height: 8rpx;
  flex: 1;
  overflow: hidden;
  border-radius: 4rpx;
  background: #edf0f2;
}

.level-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: #2f8f6f;
}

.level-card.high .level-progress-fill {
  background: #3f6fa9;
}

.level-card.cet .level-progress-fill {
  background: #7755a6;
}

.level-progress-row text {
  width: 64rpx;
  color: #858d95;
  font-size: 20rpx;
  text-align: right;
}

.level-action {
  width: 54rpx;
  height: 54rpx;
  flex: 0 0 54rpx;
  border-radius: 50%;
  background: #f0f2f3;
  color: #20242a;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 50rpx;
  text-align: center;
}

.revenge-card {
  display: grid;
  gap: 22rpx;
  padding: 28rpx;
  border: 1rpx solid #eadfdc;
  border-radius: 12rpx;
  background: #fff8f6;
}

.revenge-button {
  margin: 0;
}
