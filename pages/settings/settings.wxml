<view class="page">
  <view class="title">我的</view>
  <view class="subtitle">这里放学习设置、说明和发布前需要的合规入口。</view>

  <view class="section card summary">
    <view class="row">
      <view>
        <view class="panel-title">英语词汇复习助手</view>
        <view class="subtitle">{{loginText}}</view>
        <view class="library-text">{{libraryText}}</view>
      </view>
      <text class="pill">v0.2</text>
    </view>
    <button class="button sync-button" bindtap="loginAndSync" loading="{{syncing}}">
      {{loggedIn ? "同步学习进度" : "登录并保存进度"}}
    </button>
  </view>

  <view class="section card list">
    <view class="list-item" bindtap="openPrivacy">
      <text>隐私政策</text>
      <text class="muted">查看</text>
    </view>
    <view class="list-item" bindtap="openAgreement">
      <text>用户协议</text>
      <text class="muted">查看</text>
    </view>
  </view>

  <view class="section card list">
    <view class="list-item danger" bindtap="confirmReset">
      <text>清空学习记录</text>
      <text>重置</text>
    </view>
  </view>
</view>
