.quiz-page {
  padding-bottom: 44rpx;
}

.quiz-shell {
  min-height: 100vh;
}

.quiz-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.quiz-mode {
  color: #20242a;
  font-size: 34rpx;
  font-weight: 850;
}

.quiz-count {
  margin-top: 8rpx;
  color: #69717c;
  font-size: 24rpx;
}

.score-panel {
  width: 130rpx;
  min-height: 94rpx;
  flex: 0 0 130rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 11rpx;
  background: #173f3a;
  color: #ffffff;
  text-align: center;
}

.score-panel text:first-child {
  font-size: 34rpx;
  font-weight: 850;
}

.score-panel text:last-child {
  margin-top: 3rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 19rpx;
}

.progress-track {
  height: 10rpx;
  overflow: hidden;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #e3e8e9;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #f0b94b;
}

.question-card {
  min-height: 330rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-top: 26rpx;
  padding: 34rpx;
  border: 1rpx solid #e4e8eb;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(31, 42, 49, 0.06);
}

.question-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.question-label {
  color: #69717c;
  font-size: 25rpx;
  font-weight: 650;
}

.question-number {
  color: #b0b7bd;
  font-size: 22rpx;
  font-weight: 800;
}

.word {
  margin-top: 28rpx;
  color: #20242a;
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1.05;
  word-break: break-word;
}

.phonetic {
  margin-top: 18rpx;
  color: #176b5b;
  font-size: 30rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.tag-row text {
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 5rpx;
  background: #f0f3f3;
  color: #4d555f;
  font-size: 22rpx;
  line-height: 42rpx;
}

.options {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
}

.option {
  position: relative;
  min-height: 116rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  overflow: hidden;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e1e6e8;
  border-radius: 12rpx;
  background: #ffffff;
  color: #20242a;
  text-align: left;
  box-shadow: 0 8rpx 22rpx rgba(31, 42, 49, 0.045);
}

.option::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18rpx;
  bottom: 18rpx;
  width: 5rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #cbd2d6;
}

.option-key {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 56rpx;
  border: 1rpx solid #e3ddd0;
  border-radius: 10rpx;
  background: #f2f4f5;
  color: #4d555f;
  font-size: 24rpx;
  font-weight: 850;
  line-height: 56rpx;
  text-align: center;
}

.option-main {
  flex: 1;
  min-width: 0;
}

.option-text {
  font-size: 30rpx;
  font-weight: 780;
  line-height: 1.35;
}

.option-hint {
  margin-top: 8rpx;
  color: #8a8277;
  font-size: 22rpx;
  font-weight: 600;
}

.option-state {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  color: #a1a9af;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 48rpx;
  text-align: center;
}

.option.correct {
  border-color: rgba(23, 107, 91, 0.35);
  background: #edf8f4;
  box-shadow: 0 16rpx 38rpx rgba(23, 107, 91, 0.14);
}

.option.correct::before {
  background: #176b5b;
}

.option.correct .option-key {
  background: #176b5b;
  border-color: #176b5b;
  color: #ffffff;
}

.option.correct .option-state {
  background: #176b5b;
}

.option.correct .option-hint {
  color: #176b5b;
}

.option.wrong {
  border-color: rgba(182, 66, 60, 0.34);
  background: #fff1f0;
  box-shadow: 0 16rpx 38rpx rgba(182, 66, 60, 0.12);
}

.option.wrong::before {
  background: #b6423c;
}

.option.wrong .option-key {
  background: #b6423c;
  border-color: #b6423c;
  color: #ffffff;
}

.option.wrong .option-state {
  background: #b6423c;
}

.option.wrong .option-hint {
  color: #b6423c;
}

.feedback {
  margin-top: 24rpx;
  padding: 26rpx;
  border-left: 7rpx solid #176b5b;
  border-radius: 10rpx;
}

.feedback.ok {
  background: #e8f4ef;
}

.feedback.no {
  border-left-color: #b6423c;
  background: #fae9e8;
}

.feedback-title {
  font-size: 31rpx;
  font-weight: 850;
}

.feedback-copy,
.feedback-note {
  margin-top: 12rpx;
  color: #3b424b;
  font-size: 26rpx;
  line-height: 1.5;
}

.feedback .button {
  margin-top: 22rpx;
}

.done {
  margin-top: 100rpx;
  padding: 52rpx 34rpx 34rpx;
  border: 1rpx solid #e4e8eb;
  border-radius: 14rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 14rpx 36rpx rgba(31, 42, 49, 0.06);
}

.done-mark {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 34rpx;
  border: 14rpx solid #e4f1ed;
  border-radius: 50%;
  color: #176b5b;
  font-size: 60rpx;
  font-weight: 900;
  line-height: 152rpx;
}

.done-mark text {
  color: #7b858c;
  font-size: 26rpx;
}

.done .button {
  margin-top: 28rpx;
}
