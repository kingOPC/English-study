<view class="page quiz-page">
  <view wx:if="{{current}}" class="quiz-shell">
    <view class="quiz-top">
      <view>
        <view class="quiz-mode">{{modeTitle}}</view>
        <view class="quiz-count">第 {{currentIndex + 1}} 题，共 {{questions.length}} 题</view>
      </view>
      <view class="score-panel">
        <text>{{score}}</text>
        <text>当前得分</text>
      </view>
    </view>

    <view class="progress-track">
      <view class="progress-bar" style="width: {{progressPercent}}%;"></view>
    </view>

    <view class="question-card">
      <view class="question-label-row">
        <view class="question-label">选择正确的中文释义</view>
        <view class="question-number">Q{{currentIndex + 1}}</view>
      </view>
      <view class="word">{{current.word.text}}</view>
      <view class="phonetic">{{current.word.phonetic}}</view>
      <view class="tag-row">
        <text>{{current.word.book}}</text>
        <text>{{current.word.partOfSpeech}}</text>
      </view>
    </view>

    <view class="options">
      <view
        wx:for="{{current.options}}"
        wx:key="id"
        class="option {{answered && item.id === current.word.id ? 'correct' : ''}} {{answered && item.id === selectedId && item.id !== current.word.id ? 'wrong' : ''}}"
        data-id="{{item.id}}"
        bindtap="choose"
      >
        <view class="option-key">{{item.key}}</view>
        <view class="option-main">
          <view class="option-text">{{item.meaning}}</view>
          <view wx:if="{{!answered}}" class="option-hint">点击选择</view>
        </view>
        <view class="option-state">{{answered ? "" : "›"}}</view>
      </view>
    </view>

    <view wx:if="{{answered}}" class="feedback {{isCorrect ? 'ok' : 'no'}}">
      <view class="feedback-status"></view>
      <view class="usage-list">
        <view wx:for="{{usageExamples}}" wx:key="id" class="usage-card {{item.role}}">
          <view class="usage-head">
            <view>
              <text class="usage-word">{{item.word}}</text>
              <text class="usage-phonetic">{{item.phonetic}}</text>
            </view>
            <text class="usage-label">{{item.label}}</text>
          </view>
          <view class="usage-sentence">{{item.sentence}}</view>
          <view class="usage-translation">{{item.translation}}</view>
        </view>
      </view>
      <button class="button" bindtap="nextQuestion">{{isLast ? "查看结果" : "下一题"}}</button>
    </view>
  </view>

  <view wx:else class="done">
    <view class="done-mark">{{score}}<text>/{{total}}</text></view>
    <view class="title">挑战完成</view>
    <view class="subtitle">本轮答对 {{score}} 题。答错的词已经自动进入错题本。</view>
    <button class="button" bindtap="backHome">回到首页</button>
  </view>
</view>
