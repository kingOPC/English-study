<view class="page library-page">
  <view class="library-head">
    <view>
      <view class="title">我的词库</view>
      <view class="subtitle">按学习阶段组合，每次测试从已开启词库出题。</view>
    </view>
    <view class="library-total">
      <text>{{totalWords}}</text>
      <text>总词数</text>
    </view>
  </view>

  <view class="active-summary">已启用 {{activeCount}} / 3 个阶段</view>

  <view class="section">
    <view wx:for="{{books}}" wx:key="id" class="book {{item.tone}}">
      <view class="row">
        <view class="book-copy">
          <view class="book-title-row">
            <view class="book-name">{{item.name}}</view>
            <view class="book-label">{{item.label}}</view>
          </view>
          <view class="subtitle">{{item.description}}</view>
        </view>
        <switch checked="{{item.active}}" data-id="{{item.id}}" bindchange="toggleBook" color="#176b5b" />
      </view>
      <view class="book-data">
        <view><text>{{item.summary.total}}</text><text>词汇</text></view>
        <view><text>{{item.summary.learned}}</text><text>已学</text></view>
        <view><text>{{item.summary.mastered}}</text><text>掌握</text></view>
        <view><text>{{item.summary.mistakes}}</text><text>错题</text></view>
      </view>
      <view class="book-progress">
        <view class="book-progress-fill" style="width: {{item.learnedPercent}}%;"></view>
      </view>
      <view class="book-progress-copy">学习进度 {{item.learnedPercent}}%</view>
    </view>
  </view>

  <view class="section settings">
    <view class="panel-title">每日节奏</view>
    <view class="setting-row">
      <text>每日新词</text>
      <input type="number" value="{{settings.dailyNewCount}}" data-field="dailyNewCount" bindinput="changeNumber" />
    </view>
    <view class="setting-row">
      <text>每日复习</text>
      <input type="number" value="{{settings.dailyReviewCount}}" data-field="dailyReviewCount" bindinput="changeNumber" />
    </view>
  </view>
</view>
